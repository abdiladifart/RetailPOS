# Database Configuration
DATABASE_URL=postgresql://retailpos_user:retailpos_password@localhost:5432/retailpos_db
SQLITE_URL=sqlite:///./retailpos_offline.db

# Security
SECRET_KEY=your-secret-key-change-this-in-production-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Application
APP_NAME=RetailPOS
APP_VERSION=1.0.0
DEBUG=True

# Printer
PRINTER_NAME=default
PRINTER_WIDTH=80

# Sync
SYNC_INTERVAL_SECONDS=300
OFFLINE_MODE=False
